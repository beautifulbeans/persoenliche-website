---
import BaseLayout from "../layouts/BaseLayout.astro";
import CameraPlayground from "../components/CameraPlayground.astro";
import IntroReveal from "../components/IntroReveal.astro";
import PhotoPlaceholder from "../components/PhotoPlaceholder.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import TeaRitual from "../components/TeaRitual.astro";
import Timeline from "../components/Timeline.astro";
import { profile } from "../data/profile";
---

<BaseLayout>
  <IntroReveal />
  <SiteHeader />

  <main id="inhalt">
    <section class="hero section-shell" id="oben" aria-labelledby="hero-title">
      <div class="hero-copy">
        <h1 class="hero-name" id="hero-title" data-hero-name><span data-text="Fabian">Fabian</span><span data-text="Deragisch">Deragisch</span></h1>
        <p class="hero-statement">{profile.statement}</p>
        <div class="hero-actions">
          <a class="primary-button" href="#beruf">Berufserfahrung <i class="ph ph-arrow-down-right" aria-hidden="true"></i></a>
          <a class="secondary-button" href="#persoenlich">Persönlicher Teil</a>
        </div>
      </div>

      <div class="hero-scene" aria-label="Porträt und aktuelle berufliche Rolle">
        <div class="hero-portrait-frame">
          <span class="hero-portrait-monogram" aria-hidden="true">FD</span>
          <div class="hero-portrait-art" aria-hidden="true">
            <span class="portrait-orbit portrait-orbit-one"></span>
            <span class="portrait-orbit portrait-orbit-two"></span>
            <span class="portrait-index">01 / PORTRÄT</span>
          </div>
          <PhotoPlaceholder label="Porträt" note="Eigenes Porträt folgt" class="hero-photo" />
        </div>

        <div class="hero-role-index">
          <span aria-hidden="true"><i class="ph ph-briefcase"></i></span>
          <p><small>Aktuell als Mitarbeiter</small><strong>Marketing und E-Commerce</strong></p>
        </div>
      </div>
    </section>

    <Timeline />

    <section class="thesis-section" id="arbeit" aria-labelledby="thesis-title">
      <div class="section-shell thesis-layout">
        <div class="thesis-copy" data-reveal="left">
          <p class="section-eyebrow">Abschluss im Bachelorstudium</p>
          <h2 id="thesis-title">Bachelorarbeit: Kreative Synergien.</h2>
          <p>{profile.thesis.summary}</p>
          <div class="thesis-facts" aria-label="Angaben zur Bachelorarbeit">
            <span><i class="ph ph-graduation-cap" aria-hidden="true"></i>B.A. Medien und Kommunikation</span>
            <span><i class="ph ph-buildings" aria-hidden="true"></i>Universität Passau, 2024</span>
            <span class="thesis-future-link"><i class="ph ph-link-simple" aria-hidden="true"></i>PDF und Leseansicht folgen</span>
          </div>
        </div>

        <article class="thesis-cover" data-reveal="scale">
          <div class="cover-icons" aria-hidden="true">
            <i class="ph ph-brain"></i>
            <i class="ph ph-plus"></i>
            <i class="ph ph-paint-brush"></i>
          </div>
          <p>Medien und Kommunikation</p>
          <h3>{profile.thesis.title}</h3>
          <span>Fabian Deragisch</span>
        </article>
      </div>

      <div class="thesis-takeaways section-shell" data-reveal="up">
        <div class="takeaway-selector" role="group" aria-label="Gedanken aus der Bachelorarbeit">
          <button class="is-selected" type="button" data-thesis-note="collaboration">Zusammenarbeit</button>
          <button type="button" data-thesis-note="critical">Kritischer Blick</button>
          <button type="button" data-thesis-note="early">Mein Einstieg</button>
        </div>
        <div class="takeaway-statement">
          <span aria-hidden="true"><i class="ph ph-intersect-three"></i></span>
          <div>
            <p data-thesis-kicker>Mensch und Maschine</p>
            <h3 aria-live="polite" data-thesis-copy>
              Interessant wird KI dort, wo sie künstlerische Entscheidungen erweitert, statt sie einfach zu ersetzen.
            </h3>
          </div>
        </div>
      </div>
    </section>

    <section class="chapter-transition" id="kapitelwechsel" data-chapter-transition aria-labelledby="chapter-transition-title">
      <div class="chapter-transition-stage">
        <div class="chapter-transition-panel chapter-transition-professional" aria-hidden="true"></div>
        <div class="chapter-transition-sheet" aria-hidden="true"></div>
        <div class="chapter-transition-panel chapter-transition-personal" aria-hidden="true"></div>
        <div class="chapter-transition-number chapter-transition-number-one" aria-hidden="true">01</div>
        <div class="chapter-transition-number chapter-transition-number-two" aria-hidden="true">02</div>

        <div class="chapter-transition-center section-shell">
          <div class="chapter-transition-mark" aria-hidden="true">
            <span>I</span>
            <i class="ph ph-arrow-down-right"></i>
            <span>II</span>
          </div>
          <p>Kapitelwechsel</p>
          <h2 id="chapter-transition-title">Jetzt wird's persönlicher.</h2>
          <span class="chapter-depth-line" aria-hidden="true"></span>
        </div>
      </div>
    </section>

    <section class="personal-section" id="persoenlich" aria-labelledby="personal-title">
      <div class="section-shell personal-heading" data-reveal="up">
        <h2 id="personal-title">Abseits der Arbeit.</h2>
        <p>Interessen, Empfehlungen und kleine Dinge zum Ausprobieren.</p>
      </div>

      <div class="interest-marquee" aria-label="Persönliche Interessen">
        <div class="interest-track">
          <div class="interest-row">
            <span><i class="ph ph-leaf"></i>Grüner Tee</span>
            <span><i class="ph ph-barbell"></i>Training</span>
            <span><i class="ph ph-vinyl-record"></i>Vinyl</span>
            <span><i class="ph ph-cards-three"></i>Spielkarten</span>
            <span><i class="ph ph-camera"></i>Fotografie</span>
            <span><i class="ph ph-leaf"></i>Sencha</span>
            <span><i class="ph ph-vinyl-record"></i>IGOR</span>
            <span><i class="ph ph-camera"></i>Fujifilm</span>
            <span><i class="ph ph-poker-chip"></i>Poker</span>
            <span><i class="ph ph-cards"></i>Schafkopf</span>
          </div>
          <div class="interest-row" aria-hidden="true">
            <span><i class="ph ph-leaf"></i>Grüner Tee</span>
            <span><i class="ph ph-barbell"></i>Training</span>
            <span><i class="ph ph-vinyl-record"></i>Vinyl</span>
            <span><i class="ph ph-cards-three"></i>Spielkarten</span>
            <span><i class="ph ph-camera"></i>Fotografie</span>
            <span><i class="ph ph-leaf"></i>Sencha</span>
            <span><i class="ph ph-vinyl-record"></i>IGOR</span>
            <span><i class="ph ph-camera"></i>Fujifilm</span>
            <span><i class="ph ph-poker-chip"></i>Poker</span>
            <span><i class="ph ph-cards"></i>Schafkopf</span>
          </div>
        </div>
      </div>

      <div class="section-shell personal-grid">
        <TeaRitual />

        <article class="play-card training-card" id="training" data-reveal="right">
          <div class="play-card-heading">
            <span class="play-icon"><i class="ph ph-barbell" aria-hidden="true"></i></span>
            <h3>Training</h3>
          </div>
          <p class="training-personal">Nicht jeder Tag startet motiviert. Regelmäßigkeit heißt für mich oft einfach: hingehen und anfangen.</p>
          <button class="training-set" type="button" data-training-move data-training-stage="0" aria-label="Nächsten Trainingssatz starten">
            <span class="training-rack" aria-hidden="true">
              <span class="training-bar"></span>
              <span class="training-plate training-plate-one"></span>
              <span class="training-plate training-plate-two"></span>
              <span class="training-plate training-plate-three"></span>
              <span class="training-plate training-plate-four"></span>
            </span>
            <span class="training-set-meta">
              <small>Satz für Satz</small>
              <strong data-training-set-label>Aufwärmen</strong>
              <span data-training-set-counter>0 von 3</span>
            </span>
            <i class="ph ph-arrow-right" aria-hidden="true"></i>
          </button>
          <p class="training-move-status" aria-live="polite" data-training-move-status>Der schwierigste Teil ist oft der Weg bis zur Tür.</p>
          <p class="fact-kicker" data-training-kicker>Knochen</p>
          <p class="training-fact" aria-live="polite" data-training-copy>
            Krafttraining belastet nicht nur Muskeln. Der gezielte Widerstand setzt auch an den Knochen einen Reiz und kann sie stärken.
          </p>
          <div class="fact-switch" role="group" aria-label="Trainingsfakt auswählen">
            <button class="is-selected" type="button" data-training-fact="bone">Knochen</button>
            <button type="button" data-training-fact="neural">Nerven</button>
            <button type="button" data-training-fact="rhythm">Rhythmus</button>
          </div>
        </article>

        <article class="play-card sound-card" id="vinyl" data-reveal="left" data-sound-card data-album-theme="pink-floyd">
          <div class="sound-stage">
            <button class="vinyl-button" type="button" aria-pressed="false" data-vinyl-button>
              <i class="ph ph-vinyl-record" aria-hidden="true"></i>
              <span class="sr-only">Plattenspieler starten oder stoppen</span>
            </button>
            <span class="turntable-arm" aria-hidden="true"><span></span></span>
            <p class="turntable-caption">Vier Alben, die ich gern von Anfang bis Ende höre.</p>
          </div>
          <p class="fact-kicker">Vier Platten für den Anfang</p>
          <h3 data-album-title>The Dark Side of the Moon</h3>
          <p class="album-artist" data-album-artist>Pink Floyd, 1973</p>
          <p class="album-note" aria-live="polite" data-album-note>Ein durchgehendes Konzept über Zeit, Druck, Geld und Vergänglichkeit. Übergänge und Sounddesign machen es für mich zu einem Album am Stück.</p>
          <div class="album-switch" role="group" aria-label="Album auswählen">
            <button class="is-selected" type="button" data-album="pink-floyd">Pink Floyd</button>
            <button type="button" data-album="dire-straits">Dire Straits</button>
            <button type="button" data-album="frank-ocean">Frank Ocean</button>
            <button type="button" data-album="tyler">Tyler, the Creator</button>
          </div>
        </article>

        <article class="play-card cards-card" id="spielkarten" data-reveal="scale">
          <div class="cards-heading">
            <div>
              <p class="fact-kicker">Spiele ich gern</p>
              <h3 data-card-game-title>Durak</h3>
            </div>
            <span class="cards-icon"><i class="ph ph-cards-three" aria-hidden="true"></i></span>
          </div>
          <p class="cards-personal">Kartenspiele gehören für mich zu einem guten Abend mit Freunden.</p>
          <p class="card-game-copy" aria-live="polite" data-card-game-copy>Angreifen, verteidigen, Trumpf im Blick behalten. Verloren hat, wer am Ende noch Karten hält.</p>
          <div class="card-game-switch" role="group" aria-label="Kartenspiel auswählen">
            <button class="is-selected" type="button" data-card-game="durak">Durak</button>
            <button type="button" data-card-game="president">Präsident</button>
            <button type="button" data-card-game="neunern">Neunern</button>
            <button type="button" data-card-game="poker">Poker</button>
            <button type="button" data-card-game="schafkopf">Schafkopf</button>
          </div>
          <div class="card-deck" aria-hidden="true">
            <span class="playing-card card-back"></span>
            <span class="playing-card card-middle" data-hand-card>A<span>♣</span></span>
            <span class="playing-card card-front" data-hand-card>Q<span>♥</span></span>
          </div>
          <div class="cards-action-row">
            <button class="play-card-action" type="button" data-draw-card>
              Neu mischen <i class="ph ph-arrows-clockwise" aria-hidden="true"></i>
            </button>
            <p class="play-status" aria-live="polite" data-card-status>Die Runde ist eröffnet.</p>
          </div>
        </article>

        <CameraPlayground />
      </div>

      <details class="genealogy-teaser section-shell" data-reveal="up">
        <summary>
          <span class="genealogy-icon"><i class="ph ph-tree-structure" aria-hidden="true"></i></span>
          <span>
            <small>Ein Kapitel für später</small>
            <strong>Ahnenforschung</strong>
          </span>
          <span class="genealogy-state">Interaktiver Stammbaum folgt <i class="ph ph-caret-down" aria-hidden="true"></i></span>
        </summary>
        <div class="genealogy-content">
          <div class="family-tree-preview" aria-label="Vorschau auf den geplanten Stammbaum">
            <span><i class="ph ph-users-three" aria-hidden="true"></i>Namen</span>
            <span><i class="ph ph-map-trifold" aria-hidden="true"></i>Orte</span>
            <span><i class="ph ph-book-open-text" aria-hidden="true"></i>Geschichten</span>
          </div>
          <p>Die Forschung meines Opas soll später als kompakter Stammbaum erkundbar werden. Namen und Daten kommen erst dazu, wenn alles ausgewählt und geprüft ist.</p>
        </div>
      </details>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<script>
  const revealItems = document.querySelectorAll<HTMLElement>("[data-reveal]");

  if ("IntersectionObserver" in window) {
    const revealObserver = new IntersectionObserver(
      (entries, observer) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -8%" },
    );
    revealItems.forEach((item) => revealObserver.observe(item));
  } else {
    revealItems.forEach((item) => item.classList.add("is-visible"));
  }

  const portraitFrame = document.querySelector<HTMLElement>(".hero-portrait-frame");
  const finePointer = window.matchMedia("(hover: hover) and (pointer: fine)");
  if (portraitFrame && finePointer.matches) {
    portraitFrame.addEventListener("pointermove", (event) => {
      const bounds = portraitFrame.getBoundingClientRect();
      const x = (event.clientX - bounds.left) / bounds.width - 0.5;
      const y = (event.clientY - bounds.top) / bounds.height - 0.5;
      portraitFrame.style.transform = `perspective(900px) rotateX(${y * -4}deg) rotateY(${x * 5}deg) translateY(-0.35rem)`;
    });
    portraitFrame.addEventListener("pointerleave", () => {
      portraitFrame.style.transform = "";
    });
  }

  const chapterTransition = document.querySelector<HTMLElement>("[data-chapter-transition]");
  if (chapterTransition) {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const clamp = (value: number) => Math.min(1, Math.max(0, value));
    const smoothstep = (value: number) => value * value * (3 - 2 * value);
    const easeOut = (value: number) => 1 - Math.pow(1 - value, 3);
    let chapterFrame = 0;

    const updateChapterTransition = () => {
      chapterFrame = 0;
      const bounds = chapterTransition.getBoundingClientRect();
      const viewport = window.innerHeight;
      const rawProgress = (viewport * 0.78 - bounds.top) / (viewport * 1.18);
      const progress = reduceMotion.matches ? (rawProgress > 0.5 ? 1 : 0) : clamp(rawProgress);
      const warmProgress = easeOut(clamp(progress / 0.72));
      const personalProgress = smoothstep(clamp((progress - 0.17) / 0.83));
      const centerProgress = smoothstep(progress);

      chapterTransition.style.setProperty("--chapter-warm-y", `${116 - warmProgress * 130}%`);
      chapterTransition.style.setProperty("--chapter-personal-y", `${120 - personalProgress * 120}%`);
      chapterTransition.style.setProperty("--chapter-copy-y", `${1.25 - centerProgress * 1.25}rem`);
      chapterTransition.style.setProperty("--chapter-copy-scale", `${0.97 + centerProgress * 0.03}`);
      chapterTransition.style.setProperty("--chapter-copy-spacing", `${-0.045 + centerProgress * 0.015}em`);
      chapterTransition.style.setProperty("--chapter-arrow-rotation", `${-12 + centerProgress * 57}deg`);
      chapterTransition.style.setProperty("--chapter-line-scale", `${0.7 + centerProgress * 0.85}`);
      chapterTransition.style.setProperty("--chapter-one-opacity", `${0.7 * (1 - centerProgress)}`);
      chapterTransition.style.setProperty("--chapter-two-opacity", `${0.72 * personalProgress}`);
    };

    const requestChapterUpdate = () => {
      if (chapterFrame) return;
      chapterFrame = window.requestAnimationFrame(updateChapterTransition);
    };

    updateChapterTransition();
    window.addEventListener("scroll", requestChapterUpdate, { passive: true });
    window.addEventListener("resize", requestChapterUpdate);
    reduceMotion.addEventListener("change", requestChapterUpdate);
  }

  const storyCards = document.querySelectorAll<HTMLElement>("[data-story-card]");
  const companion = document.querySelector<HTMLElement>("[data-journey-companion]");
  const companionKind = companion?.querySelector<HTMLElement>("[data-companion-kind]");
  const companionPeriod = companion?.querySelector<HTMLElement>("[data-companion-period]");
  const companionTitle = companion?.querySelector<HTMLElement>("[data-companion-title]");
  const companionIcon = companion?.querySelector<HTMLElement>("[data-companion-icon]");

  if ("IntersectionObserver" in window && companion) {
    const storyObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          storyCards.forEach((card) => card.classList.toggle("is-active", card === entry.target));
          const card = entry.target as HTMLElement;
          if (companionKind) companionKind.textContent = card.dataset.storyKind ?? "Laufbahn";
          if (companionPeriod) companionPeriod.textContent = card.dataset.storyPeriod ?? "";
          if (companionTitle) companionTitle.textContent = card.dataset.storyTitle ?? "";
          if (companionIcon) companionIcon.className = `ph ${card.dataset.storyIcon ?? "ph-briefcase"}`;
          companion.dataset.mode = card.dataset.storyKind === "Studium" ? "study" : "work";
          companion.classList.remove("has-changed");
          requestAnimationFrame(() => companion.classList.add("has-changed"));
        });
      },
      { rootMargin: "-28% 0px -52%", threshold: 0 },
    );
    storyCards.forEach((card) => storyObserver.observe(card));
  }

  const thesisNotes = {
    collaboration: {
      kicker: "Mensch und Maschine",
      copy: "Interessant wird KI dort, wo sie künstlerische Entscheidungen erweitert, statt sie einfach zu ersetzen.",
    },
    critical: {
      kicker: "Nicht nur Potenzial",
      copy: "Zur Zusammenarbeit gehören auch Fragen nach Urheberschaft, Kontrolle und dem Wert kreativer Arbeit.",
    },
    early: {
      kicker: "Mein Einstieg in das Thema",
      copy: "Mit der Arbeit habe ich mich 2024 systematisch mit Funktionsweise, Möglichkeiten und Grenzen generativer KI beschäftigt.",
    },
  } as const;
  const thesisButtons = document.querySelectorAll<HTMLButtonElement>("[data-thesis-note]");
  const thesisKicker = document.querySelector<HTMLElement>("[data-thesis-kicker]");
  const thesisCopy = document.querySelector<HTMLElement>("[data-thesis-copy]");
  thesisButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const key = button.dataset.thesisNote as keyof typeof thesisNotes;
      const note = thesisNotes[key];
      if (!note) return;
      thesisButtons.forEach((item) => item.classList.toggle("is-selected", item === button));
      if (thesisKicker) thesisKicker.textContent = note.kicker;
      if (thesisCopy) thesisCopy.textContent = note.copy;
    });
  });

  const trainingFacts = {
    bone: {
      kicker: "Knochen",
      copy: "Krafttraining belastet nicht nur Muskeln. Der gezielte Widerstand setzt auch an den Knochen einen Reiz und kann sie stärken.",
      icon: "ph-bone",
    },
    neural: {
      kicker: "Nervensystem",
      copy: "Kraft entsteht nicht nur durch mehr Muskelmasse. Auch neuronale Anpassungen können dazu beitragen, motorische Einheiten besser zu aktivieren.",
      icon: "ph-brain",
    },
    rhythm: {
      kicker: "Rhythmus",
      copy: "Für zusätzliche gesundheitliche Vorteile empfehlen offizielle Leitlinien muskelstärkende Aktivität an mindestens zwei Tagen pro Woche.",
      icon: "ph-calendar-check",
    },
  } as const;
  const trainingButtons = document.querySelectorAll<HTMLButtonElement>("[data-training-fact]");
  const trainingKicker = document.querySelector<HTMLElement>("[data-training-kicker]");
  const trainingCopy = document.querySelector<HTMLElement>("[data-training-copy]");
  trainingButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const key = button.dataset.trainingFact as keyof typeof trainingFacts;
      const fact = trainingFacts[key];
      if (!fact) return;
      trainingButtons.forEach((item) => item.classList.toggle("is-selected", item === button));
      if (trainingKicker) trainingKicker.textContent = fact.kicker;
      if (trainingCopy) trainingCopy.textContent = fact.copy;
    });
  });

  const trainingMove = document.querySelector<HTMLButtonElement>("[data-training-move]");
  const trainingMoveStatus = document.querySelector<HTMLElement>("[data-training-move-status]");
  const trainingSetLabel = document.querySelector<HTMLElement>("[data-training-set-label]");
  const trainingSetCounter = document.querySelector<HTMLElement>("[data-training-set-counter]");
  const trainingSteps = [
    { label: "Aufwärmen", counter: "1 von 3", status: "Angefangen. Der erste Widerstand ist erledigt." },
    { label: "Arbeitssatz", counter: "2 von 3", status: "Der Rhythmus ist da. Jetzt wird konzentriert gearbeitet." },
    { label: "Letzter Satz", counter: "3 von 3", status: "Nicht spektakulär, aber erledigt. Genau darum geht es mir." },
    { label: "Neu starten", counter: "0 von 3", status: "Der schwierigste Teil ist oft der Weg bis zur Tür." },
  ];
  let trainingStep = 0;
  trainingMove?.addEventListener("click", () => {
    const step = trainingSteps[trainingStep % trainingSteps.length];
    const stage = (trainingStep % trainingSteps.length) + 1;
    trainingMove.classList.remove("is-training");
    requestAnimationFrame(() => trainingMove.classList.add("is-training"));
    trainingMove.dataset.trainingStage = String(stage === 4 ? 0 : stage);
    if (trainingSetLabel) trainingSetLabel.textContent = step.label;
    if (trainingSetCounter) trainingSetCounter.textContent = step.counter;
    if (trainingMoveStatus) trainingMoveStatus.textContent = step.status;
    trainingStep += 1;
  });

  const vinylButton = document.querySelector<HTMLButtonElement>("[data-vinyl-button]");
  vinylButton?.addEventListener("click", () => {
    const playing = vinylButton.getAttribute("aria-pressed") !== "true";
    vinylButton.setAttribute("aria-pressed", String(playing));
  });

  const albums = {
    "pink-floyd": ["The Dark Side of the Moon", "Pink Floyd, 1973", "Ein durchgehendes Konzept über Zeit, Druck, Geld und Vergänglichkeit. Übergänge und Sounddesign machen es für mich zu einem Album am Stück."],
    "dire-straits": ["Brothers in Arms", "Dire Straits, 1985", "Groß und präzise produziert, aber nie überladen. Besonders das Titelstück lebt von Raum, Dynamik und einer sehr zurückhaltenden Spannung."],
    "frank-ocean": ["Blonde", "Frank Ocean, 2016", "Reduziert, intim und stellenweise fast fragmentarisch. Viele Details und Perspektivwechsel fallen erst nach mehreren Durchläufen auf."],
    tyler: ["IGOR", "Tyler, the Creator, 2019", "Synthesizer, Soul und verzerrte Texturen erzählen eine geschlossene Geschichte. Für mich funktioniert IGOR stärker als Album als in einzelnen Songs."],
  } as const;
  const albumButtons = document.querySelectorAll<HTMLButtonElement>("[data-album]");
  const albumTitle = document.querySelector<HTMLElement>("[data-album-title]");
  const albumArtist = document.querySelector<HTMLElement>("[data-album-artist]");
  const albumNote = document.querySelector<HTMLElement>("[data-album-note]");
  const soundCard = document.querySelector<HTMLElement>("[data-sound-card]");
  albumButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const key = button.dataset.album as keyof typeof albums;
      const album = albums[key];
      if (!album) return;
      albumButtons.forEach((item) => item.classList.toggle("is-selected", item === button));
      if (albumTitle) albumTitle.textContent = album[0];
      if (albumArtist) albumArtist.textContent = album[1];
      if (albumNote) albumNote.textContent = album[2];
      if (soundCard) soundCard.dataset.albumTheme = key;
      vinylButton?.setAttribute("aria-pressed", "true");
    });
  });

  const cardGames = {
    durak: ["Durak", "Angreifen, verteidigen, Trumpf im Blick behalten. Verloren hat, wer am Ende noch Karten hält."],
    president: ["Präsident", "Karten so schnell wie möglich loswerden. Das Spiel ist auch unter einem deutlich direkteren Namen bekannt."],
    neunern: ["Neunern", "Ein schneller Klassiker für die Runde. Die genaue Variante gehört bei regionalen Kartenspielen meistens schon zur Diskussion dazu."],
    poker: ["Poker", "Wahrscheinlichkeit, Timing und die Frage, was die anderen aus wenigen Informationen machen."],
    schafkopf: ["Schafkopf", "Ein bayerischer Klassiker mit Partnerspiel, klaren Regeln und viel Taktik am Tisch."],
  } as const;
  const cardGameButtons = document.querySelectorAll<HTMLButtonElement>("[data-card-game]");
  const cardGameTitle = document.querySelector<HTMLElement>("[data-card-game-title]");
  const cardGameCopy = document.querySelector<HTMLElement>("[data-card-game-copy]");
  cardGameButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const key = button.dataset.cardGame as keyof typeof cardGames;
      const game = cardGames[key];
      if (!game) return;
      cardGameButtons.forEach((item) => item.classList.toggle("is-selected", item === button));
      if (cardGameTitle) cardGameTitle.textContent = game[0];
      if (cardGameCopy) cardGameCopy.textContent = game[1];
    });
  });

  const cardHands = [
    [["A", "♠"], ["Q", "♥"], "Ass und Dame. Die Karten liegen neu."],
    [["10", "♦"], ["K", "♣"], "Zehn und König. Noch sagt die Hand wenig."],
    [["9", "♥"], ["J", "♠"], "Neun und Bube. Neu gemischt."],
    [["7", "♣"], ["A", "♦"], "Sieben und Ass. Die nächste Runde kann beginnen."],
  ] as const;
  const drawButton = document.querySelector<HTMLButtonElement>("[data-draw-card]");
  const handCards = document.querySelectorAll<HTMLElement>("[data-hand-card]");
  const cardStatus = document.querySelector<HTMLElement>("[data-card-status]");
  let cardIndex = 0;
  drawButton?.addEventListener("click", () => {
    const hand = cardHands[cardIndex % cardHands.length];
    cardIndex += 1;
    handCards.forEach((card, index) => {
      card.innerHTML = `${hand[index][0]}<span>${hand[index][1]}</span>`;
      card.classList.remove("is-drawn");
      requestAnimationFrame(() => card.classList.add("is-drawn"));
    });
    if (cardStatus) cardStatus.textContent = hand[2];
  });
</script>
