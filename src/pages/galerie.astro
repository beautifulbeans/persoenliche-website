---
import type { ImageMetadata } from "astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectorGallery, { type ProjectorShot } from "../components/ProjectorGallery.astro";
import { photographyCopy } from "../data/photography";
import "../styles/gallery-canvas.css";

const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/fotografie/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);

const humanizeFileName = (fileName: string) =>
  fileName
    .replace(/\.[^.]+$/, "")
    .replace(/^new[-_]/i, "")
    .replace(/^\d+[\s_-]*/, "")
    .replace(/[\s_-]+/g, " ")
    .replace(/^./, (character) => character.toUpperCase());

const shots: ProjectorShot[] = Object.entries(photoModules)
  .sort(([left], [right]) => left.localeCompare(right, "de", { numeric: true }))
  .map(([path, module], index) => {
    const fileName = path.split("/").at(-1) ?? `Foto ${index + 1}`;
    const copy = photographyCopy[fileName];
    const title = copy?.title ?? humanizeFileName(fileName);
    const ratio = module.default.width / module.default.height;
    const orientation = ratio < 0.86 ? "portrait" : ratio > 1.18 ? "landscape" : "square";

    return {
      src: module.default,
      fileName,
      title,
      alt: copy?.alt ?? `${title}, fotografiert von Fabian Deragisch`,
      orientation,
      isNew: /^new[-_]/i.test(fileName),
    };
  });
---

<BaseLayout
  title="Favorite Shots | Fabian Deragisch"
  description="Eine wachsende Auswahl an Fotografien von Fabian Deragisch."
  themeColor="#111514"
  bodyClass="projector-gallery-page"
>
  <script is:inline>
    (() => {
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      let cameraArrival = false;
      let firstProjectorStart = false;

      try {
        const rawToken = sessionStorage.getItem("fabian-gallery-arrival");
        sessionStorage.removeItem("fabian-gallery-arrival");
        if (rawToken) {
          const token = JSON.parse(rawToken);
          cameraArrival = token?.kind === "camera"
            && Number.isFinite(token?.createdAt)
            && Date.now() - token.createdAt < 6000;
        }

        const projectorKey = "fabian-projector-started-v1";
        firstProjectorStart = sessionStorage.getItem(projectorKey) !== "true";
        if (firstProjectorStart) sessionStorage.setItem(projectorKey, "true");
      } catch {
        firstProjectorStart = true;
      }

      if (!reducedMotion && cameraArrival) document.documentElement.dataset.galleryArrival = "camera";
      document.documentElement.dataset.projectorIntro = reducedMotion ? "none" : firstProjectorStart ? "full" : "quick";
    })();
  </script>

  <ProjectorGallery shots={shots} />
</BaseLayout>
