---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { education, work, type TimelineEntry } from "../data/profile";

const organizationLogoModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/logos/*.{svg,png,jpg,jpeg,webp,avif}",
  { eager: true },
);

const organizationLogos = Object.fromEntries(
  Object.entries(organizationLogoModules).map(([path, module]) => [
    path.split("/").at(-1)?.replace(/\.[^.]+$/, ""),
    module.default,
  ]),
) as Record<string, ImageMetadata>;

const getOrganizationLogo = (key?: string) => (key ? organizationLogos[key] : undefined);

const getOrganizationLogoAlt = (entry: TimelineEntry) =>
  entry.logoAlt ?? (entry.organization ? `Logo von ${entry.organization}` : `Logo zu ${entry.title}`);

const getOrganizationMonogram = (entry: TimelineEntry) => {
  if (entry.logoMonogram) return entry.logoMonogram;

  const initials = entry.organization
    ?.split(/\s+/)
    .filter((word) => /[\p{L}\p{N}]/u.test(word))
    .slice(0, 3)
    .map((word) => word.match(/[\p{L}\p{N}]/u)?.[0] ?? "")
    .join("")
    .toUpperCase();

  return initials || entry.title.slice(0, 2).toUpperCase();
};
---

<section class="journey section-shell" id="laufbahn" aria-labelledby="journey-title">
  <header class="section-heading" data-reveal="up">
    <h2 id="journey-title">Beruf und Studium.</h2>
  </header>

  <div class="journey-layout">
    <aside class="journey-companion" data-journey-companion data-mode="work">
      <i class="ph ph-arrow-up-right companion-watermark" aria-hidden="true"></i>
      <div class="companion-icon" aria-hidden="true">
        <i class="ph ph-briefcase" data-companion-icon></i>
      </div>
      <p class="companion-kind" data-companion-kind>Beruf</p>
      <p class="companion-period" data-companion-period>{work[0].period}</p>
      <h3 data-companion-title>{work[0].title}</h3>
    </aside>

    <div class="journey-stories">
      <section class="journey-group" id="beruf" aria-labelledby="work-title">
        <header class="journey-group-heading">
          <span class="group-icon"><i class="ph ph-briefcase" aria-hidden="true"></i></span>
          <div>
            <p>Beruf</p>
            <h3 id="work-title">Marketing und Kommunikation</h3>
          </div>
        </header>

        <div class="journey-cards" data-timeline-group>
          {work.map((entry) => {
            const organizationLogo = getOrganizationLogo(entry.logoKey);

            return (
              <article
              class:list={["journey-card", entry.current && "is-current", entry.backDetails && "has-flip"]}
              data-flip-card={entry.backDetails ? "true" : undefined}
              data-story-card
              data-story-kind="Beruf"
              data-story-period={entry.period}
              data-story-title={entry.title}
              data-story-icon={entry.icon}
              data-timeline-point
              data-reveal="up"
            >
              <div class="journey-card-inner">
                <div class="journey-card-face journey-card-front" data-flip-front>
                  <div class="journey-card-top">
                    <span class="journey-date">{entry.period}</span>
                    {entry.logoKey ? (
                      <span
                        class:list={["journey-card-icon", "journey-organization-logo", !organizationLogo && "is-fallback"]}
                        data-logo-key={entry.logoKey}
                        role={organizationLogo ? undefined : "img"}
                        aria-label={organizationLogo ? undefined : getOrganizationLogoAlt(entry)}
                      >
                        {organizationLogo ? (
                          <Image
                            src={organizationLogo}
                            alt={getOrganizationLogoAlt(entry)}
                            width={180}
                            loading="lazy"
                            decoding="async"
                          />
                        ) : (
                          <strong aria-hidden="true">{getOrganizationMonogram(entry)}</strong>
                        )}
                      </span>
                    ) : (
                      <span class="journey-card-icon" aria-hidden="true"><i class:list={["ph", entry.icon]}></i></span>
                    )}
                  </div>
                  {entry.context && (
                    <p class="journey-context"><i class="ph ph-link-simple-horizontal" aria-hidden="true"></i>{entry.context}</p>
                  )}
                  <h4>{entry.title}</h4>
                  {entry.organization && <p class="journey-organization">{entry.organization}</p>}
                  <p class="journey-description">{entry.description}</p>
                  {entry.details && (
                    <ul class="journey-details">
                      {entry.details.map((detail) => (
                        <li><i class="ph ph-arrow-bend-down-right" aria-hidden="true"></i>{detail}</li>
                      ))}
                    </ul>
                  )}
                  {entry.backDetails && (
                    <button class="journey-flip-button" type="button" data-flip-open aria-expanded="false" aria-label={`Details zu ${entry.title} anzeigen`}>
                      Genauer ansehen <i class="ph ph-arrow-clockwise" aria-hidden="true"></i>
                    </button>
                  )}
                </div>

                {entry.backDetails && (
                  <div class="journey-card-face journey-card-back" data-flip-back aria-hidden="true" inert>
                    <div class="journey-back-top">
                      <span><i class="ph ph-list-magnifying-glass" aria-hidden="true"></i>Ein Blick dahinter</span>
                    </div>
                    <h4>{entry.backTitle}</h4>
                    <p class="journey-back-intro">{entry.backIntro}</p>
                    <div class="journey-back-grid">
                      {entry.backDetails.map((detail, index) => (
                        <article style={`--detail-index: ${index}`}>
                          <i class:list={["ph", detail.icon]} aria-hidden="true"></i>
                          <h5>{detail.title}</h5>
                          <p>{detail.text}</p>
                        </article>
                      ))}
                    </div>
                    <button class="journey-flip-button journey-flip-back-button" type="button" data-flip-close aria-label={`Vorderseite von ${entry.title} anzeigen`}>
                      Zur Vorderseite <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i>
                    </button>
                  </div>
                )}
              </div>
              </article>
            );
          })}
        </div>
      </section>

      <section class="journey-group" id="ausbildung" aria-labelledby="education-title">
        <header class="journey-group-heading">
          <span class="group-icon"><i class="ph ph-graduation-cap" aria-hidden="true"></i></span>
          <div>
            <p>Studium</p>
            <h3 id="education-title">Studium, Schule und Abschlussarbeit</h3>
          </div>
        </header>

        <div class="journey-cards journey-cards-education" data-timeline-group>
          {education.map((entry) => {
            const organizationLogo = getOrganizationLogo(entry.logoKey);

            return (
              <article
              class:list={["journey-card", "journey-card-education", entry.backDetails && "has-flip"]}
              data-flip-card={entry.backDetails ? "true" : undefined}
              data-story-card
              data-story-kind="Studium"
              data-story-period={entry.period}
              data-story-title={entry.title}
              data-story-icon={entry.icon}
              data-timeline-point
              data-reveal="up"
            >
              <div class="journey-card-inner">
                <div class="journey-card-face journey-card-front" data-flip-front>
                  <div class="journey-card-top">
                    <span class="journey-date">{entry.period}</span>
                    {entry.logoKey ? (
                      <span
                        class:list={["journey-card-icon", "journey-organization-logo", !organizationLogo && "is-fallback"]}
                        data-logo-key={entry.logoKey}
                        role={organizationLogo ? undefined : "img"}
                        aria-label={organizationLogo ? undefined : getOrganizationLogoAlt(entry)}
                      >
                        {organizationLogo ? (
                          <Image
                            src={organizationLogo}
                            alt={getOrganizationLogoAlt(entry)}
                            width={180}
                            loading="lazy"
                            decoding="async"
                          />
                        ) : (
                          <strong aria-hidden="true">{getOrganizationMonogram(entry)}</strong>
                        )}
                      </span>
                    ) : (
                      <span class="journey-card-icon" aria-hidden="true"><i class:list={["ph", entry.icon]}></i></span>
                    )}
                  </div>
                  {entry.context && (
                    <p class="journey-context"><i class="ph ph-link-simple-horizontal" aria-hidden="true"></i>{entry.context}</p>
                  )}
                  <h4>{entry.title}</h4>
                  {entry.organization && <p class="journey-organization">{entry.organization}</p>}
                  <p class="journey-description">{entry.description}</p>
                  {entry.backDetails && (
                    <button class="journey-flip-button" type="button" data-flip-open aria-expanded="false" aria-label={`Details zu ${entry.title} anzeigen`}>
                      Genauer ansehen <i class="ph ph-arrow-clockwise" aria-hidden="true"></i>
                    </button>
                  )}
                </div>

                {entry.backDetails && (
                  <div class="journey-card-face journey-card-back" data-flip-back aria-hidden="true" inert>
                    <div class="journey-back-top">
                      <span><i class="ph ph-list-magnifying-glass" aria-hidden="true"></i>Ein Blick dahinter</span>
                    </div>
                    <h4>{entry.backTitle}</h4>
                    <p class="journey-back-intro">{entry.backIntro}</p>
                    <div class="journey-back-grid">
                      {entry.backDetails.map((detail, index) => (
                        <article style={`--detail-index: ${index}`}>
                          <i class:list={["ph", detail.icon]} aria-hidden="true"></i>
                          <h5>{detail.title}</h5>
                          <p>{detail.text}</p>
                        </article>
                      ))}
                    </div>
                    <button class="journey-flip-button journey-flip-back-button" type="button" data-flip-close aria-label={`Vorderseite von ${entry.title} anzeigen`}>
                      Zur Vorderseite <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i>
                    </button>
                  </div>
                )}
              </div>
              </article>
            );
          })}
        </div>
      </section>
    </div>
  </div>
</section>

<style is:global>
  /* The uploaded logos use different canvas sizes. These presentation tokens keep
     the marks visually balanced without modifying the source files. */
  .journey .journey-card-icon.journey-organization-logo {
    --organization-logo-scale: 0.9;
    --organization-logo-shift-x: 0;
    --organization-logo-shift-y: 0;
    position: relative;
    overflow: visible;
    width: clamp(6.25rem, 8.25vw, 7.5rem);
    height: 3.65rem;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    flex: none;
  }

  .journey .journey-organization-logo img {
    position: absolute;
    inset: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    object-fit: contain;
    filter: none;
    mix-blend-mode: multiply;
    opacity: 1;
    transform: translate(var(--organization-logo-shift-x), var(--organization-logo-shift-y)) scale(var(--organization-logo-scale));
  }

  .journey .journey-organization-logo[data-logo-key="dertour-austria"] {
    --organization-logo-scale: 0.9;
  }

  .journey .journey-organization-logo[data-logo-key="landkreis-passau-gesundheit"] {
    --organization-logo-scale: 0.82;
  }

  .journey .journey-organization-logo[data-logo-key="universitaet-passau"] {
    --organization-logo-scale: 0.94;
  }

  .journey .journey-organization-logo[data-logo-key="asg-passau"] {
    --organization-logo-scale: 0.82;
  }

  .journey .journey-organization-logo.is-fallback {
    width: 3.2rem;
    height: 3.2rem;
    border: 1px solid var(--line);
    border-radius: 50%;
    background: color-mix(in srgb, var(--surface-2) 78%, transparent);
  }

  @media (hover: hover) and (pointer: fine) {
    .journey .journey-card:hover .journey-organization-logo img {
      transform: translate(var(--organization-logo-shift-x), var(--organization-logo-shift-y)) scale(var(--organization-logo-scale));
    }
  }

  @media (max-width: 48rem) {
    .journey .journey-card-icon.journey-organization-logo {
      width: 4.55rem;
      height: 2.75rem;
    }

    .journey .journey-organization-logo[data-logo-key="dertour-austria"] {
      --organization-logo-scale: 0.88;
    }

    .journey .journey-organization-logo[data-logo-key="landkreis-passau-gesundheit"] {
      --organization-logo-scale: 0.78;
    }

    .journey .journey-organization-logo[data-logo-key="universitaet-passau"] {
      --organization-logo-scale: 0.9;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .journey .journey-organization-logo img {
      transition: none;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".journey-card.has-flip").forEach((card) => {
    const openButton = card.querySelector<HTMLButtonElement>("[data-flip-open]");
    const closeButton = card.querySelector<HTMLButtonElement>("[data-flip-close]");
    const inner = card.querySelector<HTMLElement>(".journey-card-inner");
    const front = card.querySelector<HTMLElement>("[data-flip-front]");
    const back = card.querySelector<HTMLElement>("[data-flip-back]");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let flipMotion: Animation | undefined;
    let flipRun = 0;

    const setHeight = (flipped: boolean) => {
      const face = flipped ? back : front;
      if (!inner || !face) return;
      inner.style.height = `${face.scrollHeight}px`;
    };

    const setFlipped = (flipped: boolean, moveFocus = false) => {
      setHeight(flipped);
      card.classList.toggle("is-flipped", flipped);
      card.classList.add("is-flipping");
      const currentRun = ++flipRun;

      if (!reduceMotion.matches) {
        flipMotion?.cancel();
        flipMotion = card.animate(
          [
            { scale: "1" },
            { scale: "1.014", offset: 0.48 },
            { scale: "1" },
          ],
          {
            duration: flipped ? 500 : 440,
            easing: "cubic-bezier(0.23, 1, 0.32, 1)",
          },
        );
        void flipMotion.finished
          .catch(() => undefined)
          .finally(() => {
            if (currentRun === flipRun) card.classList.remove("is-flipping");
          });
      } else {
        queueMicrotask(() => card.classList.remove("is-flipping"));
      }
      openButton?.setAttribute("aria-expanded", String(flipped));
      front?.setAttribute("aria-hidden", String(flipped));
      back?.setAttribute("aria-hidden", String(!flipped));
      front?.toggleAttribute("inert", flipped);
      back?.toggleAttribute("inert", !flipped);
      if (moveFocus) {
        if (flipped) closeButton?.focus({ preventScroll: true });
        else openButton?.focus({ preventScroll: true });
      }
    };

    setHeight(false);

    openButton?.addEventListener("click", (event) => {
      event.stopPropagation();
      setFlipped(true, true);
    });
    closeButton?.addEventListener("click", (event) => {
      event.stopPropagation();
      setFlipped(false, true);
    });
    card.addEventListener("click", (event) => {
      const target = event.target as HTMLElement;
      const selection = window.getSelection();
      const selectedInsideCard =
        selection && !selection.isCollapsed && selection.anchorNode && card.contains(selection.anchorNode);
      if (target.closest("a, button") || selectedInsideCard) return;
      setFlipped(!card.classList.contains("is-flipped"));
    });

    document.fonts?.ready.then(() => setHeight(card.classList.contains("is-flipped")));

    const cardResizeObserver = new ResizeObserver(() => {
      setHeight(card.classList.contains("is-flipped"));
    });
    if (front) cardResizeObserver.observe(front);
    if (back) cardResizeObserver.observe(back);
  });

  document.querySelectorAll<HTMLElement>("[data-timeline-group]").forEach((group) => {
    const points = Array.from(group.querySelectorAll<HTMLElement>("[data-timeline-point]"));
    if (!points.length) return;

    const activatePoint = (activeIndex: number) => {
      const progress = points.length === 1 ? 1 : activeIndex / (points.length - 1);
      group.style.setProperty("--timeline-progress", String(Math.max(0, Math.min(1, progress))));
      points.forEach((point, index) => {
        point.classList.toggle("is-reached", index <= activeIndex);
        point.classList.toggle("is-timeline-current", index === activeIndex);
      });
    };

    if (!("IntersectionObserver" in window)) {
      activatePoint(points.length - 1);
      return;
    }

    const pointObserver = new IntersectionObserver(
      (entries) => {
        const entering = entries
          .filter((entry) => entry.isIntersecting)
          .sort((left, right) => left.boundingClientRect.top - right.boundingClientRect.top);
        const target = entering.at(-1)?.target as HTMLElement | undefined;
        if (!target) return;
        const index = points.indexOf(target);
        if (index >= 0) activatePoint(index);
      },
      { rootMargin: "-42% 0px -48%", threshold: 0 },
    );

    points.forEach((point) => pointObserver.observe(point));
  });

</script>
