---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

const coverModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/vinyl/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);

const albums = [
  {
    key: "pink-floyd",
    coverFile: "dark-side-of-the-moon.jpg",
    title: "The Dark Side of the Moon",
    artist: "Pink Floyd",
    year: "1973",
    monogram: "DS",
    tracks: [
      { position: "04", title: "Time" },
      { position: "05", title: "The Great Gig in the Sky" },
      { position: "08", title: "Any Colour You Like" },
    ],
  },
  {
    key: "dire-straits",
    coverFile: "dire-straits.jpg",
    title: "Dire Straits",
    artist: "Dire Straits",
    year: "1978",
    monogram: "DR",
    tracks: [
      { position: "06", title: "Sultans of Swing" },
      { position: "04", title: "Six Blade Knife" },
      { position: "01", title: "Down to the Waterline" },
    ],
  },
  {
    key: "frank-ocean",
    coverFile: "blonde.jpg",
    title: "Blonde",
    artist: "Frank Ocean",
    year: "2016",
    monogram: "BL",
    tracks: [
      { position: "09", title: "Nights" },
      { position: "14", title: "White Ferrari" },
      { position: "15", title: "Seigfried" },
    ],
  },
  {
    key: "tyler",
    coverFile: "igor.jpg",
    title: "IGOR",
    artist: "Tyler, the Creator",
    year: "2019",
    monogram: "IG",
    tracks: [
      { position: "01", title: "IGOR'S THEME" },
      { position: "08", title: "PUPPET" },
      { position: "12", title: "ARE WE STILL FRIENDS?" },
    ],
  },
  {
    key: "mac-miller",
    coverFile: "swimming.jpg",
    title: "Swimming",
    artist: "Mac Miller",
    year: "2018",
    monogram: "SW",
    tracks: [
      { position: "03", title: "What's the Use?" },
      { position: "06", title: "Wings" },
      { position: "10", title: "Dunno" },
    ],
  },
].map((album) => ({
  ...album,
  cover: coverModules[`../assets/vinyl/${album.coverFile}`]?.default,
}));
---

<article class="play-card sound-card" id="vinyl" data-reveal="left" data-sound-card data-album-theme={albums[0].key}>
  <header class="vinyl-intro">
    <span class="vinyl-intro-icon" aria-hidden="true"><i class="ph ph-vinyl-record"></i></span>
    <div>
      <h3>Schallplatten, die ich gern auflege.</h3>
      <p>Ich höre Musik nicht nur auf Vinyl. Schallplatten mag ich trotzdem – und wenn eine aufliegt, höre ich ein Album automatisch etwas bewusster. Der Seitenwechsel gehört einfach dazu.</p>
    </div>
  </header>

  <div class="vinyl-console">
    <div class="turntable" data-turntable>
      <button class="vinyl-button" type="button" aria-pressed="true" data-vinyl-button>
        <span class="vinyl-disc" aria-hidden="true">
          <span class="vinyl-disc-label">
            <strong data-vinyl-monogram>{albums[0].monogram}</strong>
            <i></i>
          </span>
        </span>
        <span class="sr-only">Plattenspieler starten oder stoppen</span>
      </button>
      <span class="turntable-arm" aria-hidden="true"><span></span></span>
      <span class="vinyl-nudge" aria-hidden="true"><i></i></span>
    </div>

    <div class="album-copy-stack" aria-live="polite">
      {albums.map((album, index) => (
        <section class:list={["album-copy-panel", index === 0 && "is-active"]} data-album-detail={album.key} hidden={index !== 0}>
          <p class="album-artist">{album.artist}, {album.year}</p>
          <h3>{album.title}</h3>
          <div class="favorite-tracks">
            <span>Meine Favoriten</span>
            <ol>
              {album.tracks.map((track) => (
                <li><span>{track.position}</span><strong>{track.title}</strong></li>
              ))}
            </ol>
          </div>
        </section>
      ))}
    </div>
  </div>

  <div class="album-library" role="group" aria-label="Album auswählen">
    {albums.map((album, index) => (
      <button class:list={["album-choice", index === 0 && "is-selected"]} type="button" data-album={album.key} data-album-monogram={album.monogram} aria-pressed={index === 0}>
        <span class="album-choice-cover">
          {album.cover ? (
            <Image src={album.cover} alt={`Cover von ${album.title} von ${album.artist}`} widths={[180, 320]} sizes="(max-width: 40rem) 7.5rem, 8.5rem" loading="lazy" />
          ) : (
            <span class="album-choice-fallback" aria-label={`${album.title} - Cover kann lokal ergänzt werden`}>
              <strong>{album.monogram}</strong>
            </span>
          )}
        </span>
        <span class="album-choice-copy">
          <strong>{album.title}</strong>
          <small>{album.artist}</small>
        </span>
      </button>
    ))}
  </div>
</article>

<script>
  import { prefersReducedMotion, setPressedState } from "../scripts/motion";

  document.querySelectorAll<HTMLElement>("[data-sound-card]").forEach((soundCard) => {
    const vinylButton = soundCard.querySelector<HTMLButtonElement>("[data-vinyl-button]");
    const turntable = soundCard.querySelector<HTMLElement>("[data-turntable]");
    const vinylMonogram = soundCard.querySelector<HTMLElement>("[data-vinyl-monogram]");
    const albumButtons = Array.from(soundCard.querySelectorAll<HTMLButtonElement>("[data-album]"));
    const panels = Array.from(soundCard.querySelectorAll<HTMLElement>("[data-album-detail]"));
    let rescueTimer = 0;
    let rescueRestartTimer = 0;
    let rescueFinishTimer = 0;
    let albumRun = 0;

    const setPlaying = (playing: boolean) => {
      vinylButton?.setAttribute("aria-pressed", String(playing));
    };

    const clearRescue = () => {
      window.clearTimeout(rescueTimer);
      window.clearTimeout(rescueRestartTimer);
      window.clearTimeout(rescueFinishTimer);
      turntable?.classList.remove("is-rescuing");
    };

    const scheduleRescue = () => {
      clearRescue();
      rescueTimer = window.setTimeout(() => {
        if (vinylButton?.getAttribute("aria-pressed") === "true") return;
        turntable?.classList.add("is-rescuing");
        rescueRestartTimer = window.setTimeout(() => setPlaying(true), prefersReducedMotion() ? 0 : 790);
        rescueFinishTimer = window.setTimeout(() => {
          turntable?.classList.remove("is-rescuing");
        }, prefersReducedMotion() ? 100 : 1700);
      }, 5000);
    };

    vinylButton?.addEventListener("click", () => {
      const playing = vinylButton.getAttribute("aria-pressed") === "true";
      clearRescue();
      setPlaying(!playing);
      if (playing) scheduleRescue();
    });

    albumButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const key = button.dataset.album;
        if (!key) return;
        const currentRun = ++albumRun;
        setPressedState(albumButtons, button);
        soundCard.dataset.albumTheme = key;
        if (vinylMonogram) vinylMonogram.textContent = button.dataset.albumMonogram ?? "FD";

        panels.forEach((panel) => {
          const active = panel.dataset.albumDetail === key;
          panel.classList.toggle("is-active", active);
          panel.toggleAttribute("hidden", !active);
          if (active && !prefersReducedMotion()) {
            panel.animate(
              [
                { opacity: 0, transform: "translate3d(0, 1.25rem, 0) scale(0.985)", clipPath: "inset(100% 0 0 0)" },
                { opacity: 1, transform: "translate3d(0, 0, 0) scale(1)", clipPath: "inset(0 0 0 0)" },
              ],
              { duration: 440, easing: "cubic-bezier(0.23, 1, 0.32, 1)" },
            );
          }
        });
        if (currentRun !== albumRun) return;
        clearRescue();
        setPlaying(true);
      });
    });
  });
</script>
