<script>
  import { prefersReducedMotion } from "../scripts/motion";

  let scrollFrame = 0;
  let activeLink: HTMLAnchorElement | undefined;

  const easeInOutCubic = (value: number) =>
    value < 0.5 ? 4 * value * value * value : 1 - Math.pow(-2 * value + 2, 3) / 2;

  const stopJourney = () => {
    if (scrollFrame) window.cancelAnimationFrame(scrollFrame);
    scrollFrame = 0;
    activeLink?.removeAttribute("data-anchor-travelling");
    activeLink = undefined;
  };

  const finishJourney = (
    link: HTMLAnchorElement,
    target: HTMLElement,
    keyboardActivation: boolean,
  ) => {
    history.pushState(null, "", link.hash);
    if (keyboardActivation) {
      target.setAttribute("tabindex", "-1");
      target.focus({ preventScroll: true });
    }
    stopJourney();
  };

  const travelTo = (
    link: HTMLAnchorElement,
    target: HTMLElement,
    keyboardActivation: boolean,
  ) => {
    const header = document.querySelector<HTMLElement>("[data-site-header]");
    const headerOffset = (header?.offsetHeight ?? 64) + 24;
    const startY = window.scrollY;
    const destinationY = Math.max(
      0,
      target.getBoundingClientRect().top + window.scrollY - headerOffset,
    );
    const distance = destinationY - startY;

    if (prefersReducedMotion() || Math.abs(distance) < 8) {
      window.scrollTo({ top: destinationY });
      finishJourney(link, target, keyboardActivation);
      return;
    }

    stopJourney();
    activeLink = link;
    link.setAttribute("data-anchor-travelling", "true");

    const icon = link.querySelector<HTMLElement>(
      ".journey-switcher-arrow, .ph-arrow-down-right, .ph-arrow-down",
    );
    icon?.animate(
      distance >= 0
        ? [
            { transform: "translate3d(0, 0, 0)" },
            { transform: "translate3d(0.22rem, 0.3rem, 0)", offset: 0.48 },
            { transform: "translate3d(0, 0, 0)" },
          ]
        : [
            { transform: "translate3d(0, 0, 0)" },
            { transform: "translate3d(-0.18rem, -0.28rem, 0)", offset: 0.48 },
            { transform: "translate3d(0, 0, 0)" },
          ],
      {
        duration: 420,
        easing: "cubic-bezier(0.23, 1, 0.32, 1)",
      },
    );

    const duration = Math.min(900, Math.max(500, 420 + Math.abs(distance) * 0.09));
    const startedAt = performance.now();
    const step = (time: number) => {
      const progress = Math.min(1, (time - startedAt) / duration);
      window.scrollTo({ top: startY + distance * easeInOutCubic(progress) });

      if (progress < 1) {
        scrollFrame = window.requestAnimationFrame(step);
        return;
      }

      finishJourney(link, target, keyboardActivation);
    };

    scrollFrame = window.requestAnimationFrame(step);
  };

  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((link) => {
    link.addEventListener("click", (event) => {
      if (!link.hash || link.hash === "#") return;
      const target = document.getElementById(decodeURIComponent(link.hash.slice(1)));
      if (!target) return;
      event.preventDefault();
      travelTo(link, target, event.detail === 0);
    });
  });

  window.addEventListener("wheel", stopJourney, { passive: true });
  window.addEventListener("touchstart", stopJourney, { passive: true });
</script>
