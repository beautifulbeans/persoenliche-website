---
import { profile } from "../data/profile";
---

<header class="site-header" data-site-header>
  <div class="header-identity">
    <a class="wordmark" href="#oben" aria-label="Zurück zum Anfang">
      <span aria-hidden="true">FD</span>
      <span class="wordmark-name">Fabian Deragisch</span>
    </a>

    <button
      class="header-note"
      type="button"
      data-header-note
      data-notes={JSON.stringify(profile.statusNotes)}
      aria-label="Persönliche Statusnotiz wechseln"
      title="Notiz wechseln"
    >
      <span class="header-note-mark" aria-hidden="true">
        <i class:list={["ph", profile.statusNotes[0].icon]} data-header-note-icon></i>
      </span>
      <span class="header-note-copy" aria-live="polite">
        <small data-header-note-label>{profile.statusNotes[0].label}</small>
        <strong data-header-note-text>{profile.statusNotes[0].text}</strong>
      </span>
      <span class="header-note-cycle" aria-hidden="true"><i class="ph ph-arrow-bend-down-right"></i></span>
    </button>
  </div>

  <nav aria-label="Hauptnavigation">
    <a href="#beruf"><span class="nav-long">Berufserfahrung</span><span class="nav-short">Beruf</span></a>
    <a href="#ausbildung"><span class="nav-long">Studium + Bachelorarbeit</span><span class="nav-short">Studium</span></a>
    <a href="#persoenlich"><span class="nav-long">Persönlich</span><span class="nav-short">Privat</span></a>
    <a href="#kontakt"><span>Kontakt</span></a>
  </nav>
</header>

<script>
  import { animateContentSwap } from "../scripts/motion";

  document.querySelectorAll<HTMLButtonElement>("[data-header-note]").forEach((button) => {
    const notes = JSON.parse(button.dataset.notes ?? "[]") as Array<{ icon: string; label: string; text: string }>;
    const icon = button.querySelector<HTMLElement>("[data-header-note-icon]");
    const labels = button.querySelectorAll<HTMLElement>("[data-header-note-label]");
    const text = button.querySelector<HTMLElement>("[data-header-note-text]");
    let noteIndex = 0;

    button.addEventListener("click", () => {
      if (!notes.length) return;
      noteIndex = (noteIndex + 1) % notes.length;
      const note = notes[noteIndex];
      animateContentSwap(
        [button.querySelector<HTMLElement>(".header-note-mark"), button.querySelector<HTMLElement>(".header-note-copy")],
        () => {
          if (icon) icon.className = `ph ${note.icon}`;
          labels.forEach((label) => (label.textContent = note.label));
          if (text) text.textContent = note.text;
        },
        { duration: 190, offset: 3, stagger: 0 },
      );
    });
  });

  const siteHeader = document.querySelector<HTMLElement>("[data-site-header]");
  const sectionLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-site-header] nav a[href^='#']"));
  const observedSections = sectionLinks
    .map((link) => {
      const id = link.hash.slice(1);
      const section = document.getElementById(id);
      return section ? { link, section } : null;
    })
    .filter((entry): entry is { link: HTMLAnchorElement; section: HTMLElement } => Boolean(entry));

  const setCurrentSection = (activeLink: HTMLAnchorElement) => {
    sectionLinks.forEach((link) => {
      if (link === activeLink) link.setAttribute("aria-current", "location");
      else link.removeAttribute("aria-current");
    });
    siteHeader?.setAttribute("data-section-mode", activeLink.hash === "#persoenlich" || activeLink.hash === "#kontakt" ? "personal" : "professional");
  };

  if ("IntersectionObserver" in window) {
    const navigationObserver = new IntersectionObserver(
      (entries) => {
        const active = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (!active) return;
        const match = observedSections.find(({ section }) => section === active.target);
        if (match) setCurrentSection(match.link);
      },
      { rootMargin: "-18% 0px -62%", threshold: [0, 0.12, 0.4] },
    );
    observedSections.forEach(({ section }) => navigationObserver.observe(section));
  }

  sectionLinks.forEach((link) => link.addEventListener("click", () => setCurrentSection(link)));
</script>
