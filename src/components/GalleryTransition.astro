<div class="gallery-page-transition" data-gallery-page-transition aria-hidden="true">
  <span class="gallery-transition-flash"></span>
  <span class="gallery-transition-shutter gallery-transition-shutter-top"></span>
  <span class="gallery-transition-shutter gallery-transition-shutter-bottom"></span>
  <span class="gallery-transition-focus">
    <i></i><i></i><i></i><i></i>
  </span>
</div>

<script is:inline>
  (() => {
    const transition = document.querySelector("[data-gallery-page-transition]");
    if (!(transition instanceof HTMLElement)) return;

    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    document.addEventListener("click", (event) => {
      if (!(event instanceof MouseEvent) || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
      if (!(event.target instanceof Element)) return;

      const link = event.target.closest('a[href="/galerie/"], a[href="/galerie"]');
      if (!(link instanceof HTMLAnchorElement) || reducedMotion.matches) return;
      event.preventDefault();

      try {
        sessionStorage.setItem("fabian-gallery-arrival", "camera");
      } catch {
        /* Navigation still works when storage is unavailable. */
      }

      transition.classList.add("is-capturing");
      document.body.classList.add("gallery-transition-active");
      window.setTimeout(() => window.location.assign(link.href), 720);
    });
  })();
</script>
