---
const base = import.meta.env.BASE_URL;
---

<footer class="site-footer" id="kontakt">
  <section class="pigeon-contact section-shell" aria-labelledby="contact-title" data-reveal="up">
    <div class="contact-copy">
      <p class="contact-eyebrow">Kontakt</p>
      <h2 id="contact-title">Sag einfach Hallo.</h2>
      <p>E-Mail, LinkedIn oder Instagram. Beim Klick fliegt die Taube mit.</p>
    </div>

    <div class="contact-panel">
      <div class="contact-routes" aria-label="Kontaktwege">
        <a href="mailto:fabian.deragisch@gmail.com" data-contact-route="E-Mail" data-route-kind="mail">
          <span class="contact-route-number">01</span>
          <i class="ph ph-envelope-simple" aria-hidden="true"></i>
          <span>E-Mail</span>
          <i class="ph ph-arrow-up-right route-arrow" aria-hidden="true"></i>
        </a>
        <a href="https://at.linkedin.com/in/fabian-deragisch-57769a2a2" target="_blank" rel="noreferrer" data-contact-route="LinkedIn" data-route-kind="linkedin">
          <span class="contact-route-number">02</span>
          <i class="ph ph-linkedin-logo" aria-hidden="true"></i>
          <span>LinkedIn</span>
          <i class="ph ph-arrow-up-right route-arrow" aria-hidden="true"></i>
        </a>
        <a href="https://www.instagram.com/fabian.deragisch/" target="_blank" rel="noreferrer" data-contact-route="Instagram" data-route-kind="instagram">
          <span class="contact-route-number">03</span>
          <i class="ph ph-instagram-logo" aria-hidden="true"></i>
          <span>Instagram</span>
          <i class="ph ph-arrow-up-right route-arrow" aria-hidden="true"></i>
        </a>
      </div>

      <div class="pigeon-stage" data-pigeon-stage>
        <div class="pigeon-route" aria-hidden="true">
          <span class="route-cloud route-cloud-one"><i class="ph ph-cloud"></i></span>
          <span class="route-cloud route-cloud-two"><i class="ph ph-cloud"></i></span>
          <span class="route-feather route-feather-one"><i class="ph ph-feather"></i></span>
          <span class="route-feather route-feather-two"><i class="ph ph-feather"></i></span>
          <span class="route-start"><i class="ph ph-envelope-simple"></i><small>Los</small></span>
          <span class="route-line"></span>
          <span class="pigeon" data-pigeon>
            <i class="ph ph-bird"></i>
            <i class="ph ph-envelope-simple pigeon-letter"></i>
          </span>
          <span class="route-finish"><i class="ph ph-mailbox"></i><small>Postfach</small></span>
        </div>
        <p class="pigeon-status" aria-live="polite" data-pigeon-status>Kontaktweg wählen. Die Taube übernimmt den Rest.</p>
      </div>
    </div>
  </section>

  <div class="footer-bottom section-shell">
    <p>Fabian Deragisch <span data-current-year></span></p>
    <p class="privacy-note">Kein Tracking. Keine Werbung. Keine Cookies durch diese Website.</p>
    <nav aria-label="Rechtliche Hinweise">
      <a href={`${base}impressum/`}>Impressum</a>
      <a href={`${base}datenschutz/`}>Datenschutz</a>
    </nav>
  </div>
</footer>

<script>
  const year = document.querySelector<HTMLElement>("[data-current-year]");
  if (year) year.textContent = String(new Date().getFullYear());

  const pigeon = document.querySelector<HTMLElement>("[data-pigeon]");
  const pigeonStatus = document.querySelector<HTMLElement>("[data-pigeon-status]");
  const pigeonStage = document.querySelector<HTMLElement>("[data-pigeon-stage]");
  const routeLinks = document.querySelectorAll<HTMLElement>("[data-contact-route]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  routeLinks.forEach((link) => {
    link.addEventListener("click", (event) => {
      const route = link.dataset.contactRoute ?? "Kontakt";
      const mailLink = link.dataset.routeKind === "mail" && link instanceof HTMLAnchorElement ? link.href : null;
      if (mailLink) event.preventDefault();
      routeLinks.forEach((item) => {
        const selected = item === link;
        item.classList.toggle("is-selected", selected);
        if (item instanceof HTMLButtonElement) item.setAttribute("aria-pressed", String(selected));
      });
      pigeonStage?.classList.remove("is-dispatched");
      requestAnimationFrame(() => pigeonStage?.classList.add("is-dispatched"));

      if (pigeon && pigeonStage && !reduceMotion.matches) {
        pigeon.getAnimations().forEach((animation) => animation.cancel());
        const travel = Math.max(110, pigeonStage.clientWidth - 150);
        pigeon.animate(
          [
            { transform: "translate3d(0, 0, 0) rotate(-8deg) scale(0.94)", offset: 0 },
            { transform: `translate3d(${travel * 0.22}px, -2.5rem, 0) rotate(9deg) scale(1.08)`, offset: 0.24 },
            { transform: `translate3d(${travel * 0.48}px, 0.7rem, 0) rotate(-7deg) scale(1)`, offset: 0.5 },
            { transform: `translate3d(${travel * 0.74}px, -2rem, 0) rotate(6deg) scale(1.04)`, offset: 0.76 },
            { transform: `translate3d(${travel}px, 0, 0) rotate(0deg) scale(0.92)`, offset: 1 },
          ],
          { duration: 1450, easing: "cubic-bezier(0.32, 0.72, 0, 1)" },
        );
      }
      if (pigeonStatus) {
        pigeonStatus.textContent = `${route} ist unterwegs.`;
      }

      if (mailLink) {
        window.setTimeout(() => {
          window.location.href = mailLink;
        }, reduceMotion.matches ? 0 : 650);
      }
    });
  });
</script>
