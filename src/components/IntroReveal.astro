---
import { Image } from "astro:assets";
import portrait from "../assets/portrait/fabian-deragisch.jpg";
---

<div class="intro-reveal" data-intro-reveal aria-hidden="true">
  <div class="intro-shutter intro-shutter-top"></div>

  <div class="intro-focus-band">
    <Image
      class="intro-focus-image"
      src={portrait}
      alt=""
      width={1200}
      quality={84}
      loading="eager"
    />
    <span class="intro-focus-scan"></span>
  </div>

  <div class="intro-focus-name">
    <span>Fabian</span>
    <span>Deragisch</span>
  </div>

  <div class="intro-shutter intro-shutter-bottom"></div>
</div>

<script is:inline>
  (() => {
    const intro = document.querySelector("[data-intro-reveal]");
    if (!(intro instanceof HTMLElement)) return;

    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let alreadySeen = false;

    try {
      alreadySeen = sessionStorage.getItem("fabian-intro-seen-v7") === "true";
      sessionStorage.setItem("fabian-intro-seen-v7", "true");
    } catch {
      alreadySeen = false;
    }

    if (alreadySeen || reducedMotion) {
      intro.remove();
      document.body.classList.add("intro-complete");
      return;
    }

    document.body.classList.add("intro-active");
    requestAnimationFrame(() => intro.classList.add("is-running"));

    window.setTimeout(() => {
      intro.classList.add("is-leaving");
      document.body.classList.add("intro-complete");
      document.body.classList.remove("intro-active");
    }, 1450);

    window.setTimeout(() => intro.remove(), 2350);
  })();
</script>

<noscript><style>.intro-reveal{display:none}</style></noscript>
