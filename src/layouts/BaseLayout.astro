---
import "@fontsource-variable/cormorant-garamond/index.css";
import "@fontsource-variable/manrope/index.css";
import "@phosphor-icons/web/regular/style.css";
import "../styles/global.css";
import "../styles/refinement.css";
import "../styles/latest.css";
import "../styles/photographic-opening.css";

interface Props {
  title?: string;
  description?: string;
  robots?: string;
}

const {
  title = "Fabian Deragisch | Marketing und E-Commerce",
  description =
    "Persönliche Website und berufliche Laufbahn von Fabian Deragisch.",
  robots = "index, follow",
} = Astro.props;

const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#f2f3ed" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>F</text></svg>" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#inhalt">Zum Inhalt springen</a>
    <slot />
  </body>
</html>
